generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["iam", "campaign", "market", "content", "repository", "audit"]
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaigns Campaign[]

  @@index([id])
  @@map("organizations")
  @@schema("iam")
}

model Campaign {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, id])
  @@map("campaigns")
  @@schema("campaign")
}

model OutboxEvent {
  id             String    @id @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  eventType      String    @map("event_type")
  payload        Json
  processed      Boolean   @default(false)
  processedAt    DateTime? @map("processed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([organizationId, id])
  @@index([processed, createdAt])
  @@map("outbox_events")
  @@schema("audit")
}

model ProcessedEventLog {
  organizationId String   @map("organization_id") @db.Uuid
  eventId        String   @map("event_id") @db.Uuid
  consumerName   String   @map("consumer_name")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@id([organizationId, eventId, consumerName])
  @@map("processed_event_log")
  @@schema("audit")
}

model EventReceipt {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  eventId        String   @map("event_id") @db.Uuid
  eventType      String   @map("event_type")
  consumerName   String   @map("consumer_name")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, eventId])
  @@map("event_receipts")
  @@schema("audit")
}
