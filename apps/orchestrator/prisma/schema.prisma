generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["iam", "campaign", "market", "content", "repository", "audit"]
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaigns Campaign[]

  @@index([id])
  @@map("organizations")
  @@schema("iam")
}

model Campaign {
  id                   String                @id @default(uuid()) @db.Uuid
  organizationId       String                @map("organization_id") @db.Uuid
  name                 String
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  organization         Organization          @relation(fields: [organizationId], references: [id])
  generationTasks GenerationTask[]
  marketAnalysisRequests MarketAnalysisRequest[]
  qualifiedTopics        QualifiedTopic[]
  sitemapIngestions      SitemapIngestion[]
  articleBlueprints      ArticleBlueprint[]

  @@index([organizationId, id])
  @@map("campaigns")
  @@schema("campaign")
}

model MarketAnalysisRequest {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  campaignId     String   @map("campaign_id") @db.Uuid
  seedTopic      String?  @map("seed_topic")
  industry       String?
  autoDiscover   Boolean  @default(false) @map("auto_discover")
  discoveredTopics Json?  @map("discovered_topics")
  targetAudience String?  @map("target_audience")
  contentLanguage String? @map("content_language")
  geoContext     String?  @map("geo_context")
  status         String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  campaign       Campaign @relation(fields: [campaignId], references: [id])

  @@index([organizationId, id])
  @@index([campaignId, id])
  @@map("market_analysis_requests")
  @@schema("market")
}

model QualifiedTopic {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  campaignId        String   @map("campaign_id") @db.Uuid
  analysisRequestId String   @map("analysis_request_id") @db.Uuid
  topic             String
  score             Float
  trendScore        Float    @map("trend_score")
  socialScore       Float    @map("social_score")
  seoScore          Float    @map("seo_score")
  qualificationNote String   @map("qualification_note")
  sourceMetadata    Json     @map("source_metadata")
  createdAt         DateTime @default(now()) @map("created_at")
  campaign          Campaign @relation(fields: [campaignId], references: [id])

  @@index([organizationId, id])
  @@index([campaignId, score])
  @@index([analysisRequestId])
  @@map("qualified_topics")
  @@schema("market")
}

model GenerationTask {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  campaignId       String   @map("campaign_id") @db.Uuid
  topic            String
  targetAudience   String?  @map("target_audience")
  contentLanguage  String?  @map("content_language")
  geoContext       String?  @map("geo_context")
  outputFormats    Json     @map("output_formats")
  status           String
  qualifiedTopicId String?  @map("qualified_topic_id") @db.Uuid
  blueprintId      String?  @map("blueprint_id") @db.Uuid
  blueprintJson    Json?    @map("blueprint_json")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  completedAt      DateTime? @map("completed_at")
  campaign         Campaign @relation(fields: [campaignId], references: [id])

  @@index([organizationId, id])
  @@index([campaignId, id])
  @@map("generation_tasks")
  @@schema("content")
}

model GenerationRun {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  taskId         String   @map("task_id") @db.Uuid
  campaignId     String   @map("campaign_id") @db.Uuid
  status         String
  stateJson      Json     @map("state_json")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([taskId])
  @@index([organizationId, id])
  @@map("generation_runs")
  @@schema("content")
}

model DraftRevision {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  taskId         String   @map("task_id") @db.Uuid
  runId          String   @map("run_id") @db.Uuid
  revisionNumber Int      @map("revision_number")
  title          String
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([taskId, revisionNumber])
  @@index([organizationId, taskId])
  @@map("draft_revisions")
  @@schema("content")
}

model QaFeedback {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  taskId         String   @map("task_id") @db.Uuid
  runId          String   @map("run_id") @db.Uuid
  revisionNumber Int      @map("revision_number")
  passed         Boolean
  feedback       String
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([taskId, revisionNumber])
  @@index([organizationId, taskId])
  @@map("qa_feedback")
  @@schema("content")
}

model RepositoryArticle {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  campaignId     String   @map("campaign_id") @db.Uuid
  taskId         String   @map("task_id") @db.Uuid
  title          String
  body           String
  status         String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([taskId])
  @@index([organizationId, id])
  @@map("articles")
  @@schema("repository")
}

model SitemapIngestion {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  campaignId     String   @map("campaign_id") @db.Uuid
  sitemapUrl     String   @map("sitemap_url")
  status         String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  campaign       Campaign @relation(fields: [campaignId], references: [id])

  @@index([organizationId, id])
  @@index([campaignId, id])
  @@map("sitemap_ingestions")
  @@schema("content")
}

model IndexedPage {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  campaignId         String   @map("campaign_id") @db.Uuid
  sitemapIngestionId String   @map("sitemap_ingestion_id") @db.Uuid
  url                String
  title              String
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([organizationId, sitemapIngestionId])
  @@index([campaignId, id])
  @@map("indexed_pages")
  @@schema("content")
}

model ArticleBlueprint {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  campaignId         String   @map("campaign_id") @db.Uuid
  qualifiedTopicId   String   @map("qualified_topic_id") @db.Uuid
  sitemapIngestionId String?  @map("sitemap_ingestion_id") @db.Uuid
  topic              String
  status             String
  blueprintJson      Json     @map("blueprint_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  campaign           Campaign @relation(fields: [campaignId], references: [id])

  @@unique([qualifiedTopicId])
  @@index([organizationId, id])
  @@index([campaignId, id])
  @@map("article_blueprints")
  @@schema("content")
}

model InternalLink {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  campaignId     String   @map("campaign_id") @db.Uuid
  blueprintId    String   @map("blueprint_id") @db.Uuid
  url            String
  title          String
  anchorText     String   @map("anchor_text")
  rationale      String
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, blueprintId])
  @@index([campaignId, id])
  @@map("internal_links")
  @@schema("content")
}

model OutboxEvent {
  id             String    @id @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  eventType      String    @map("event_type")
  payload        Json
  processed      Boolean   @default(false)
  processedAt    DateTime? @map("processed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([organizationId, id])
  @@index([processed, createdAt])
  @@map("outbox_events")
  @@schema("audit")
}

model ProcessedEventLog {
  organizationId String   @map("organization_id") @db.Uuid
  eventId        String   @map("event_id") @db.Uuid
  consumerName   String   @map("consumer_name")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@id([organizationId, eventId, consumerName])
  @@map("processed_event_log")
  @@schema("audit")
}

model EventReceipt {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  eventId        String   @map("event_id") @db.Uuid
  eventType      String   @map("event_type")
  consumerName   String   @map("consumer_name")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, eventId])
  @@map("event_receipts")
  @@schema("audit")
}
